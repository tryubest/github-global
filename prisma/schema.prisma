// M0 核心表 + WebhookEvent + TranslationJob / FileTranslation（TechDesign §3.2）

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // directUrl 不强制写第二 env：Vercel 上易漏配 UNPOOLED 导致 P1012；迁移与运行时共用 `url`（Neon pooler 在多数项目可通）。
  // 需要单独直连时可在 DATABASE_URL 使用 non-pooler 串，或恢复 directUrl=env("DATABASE_URL_UNPOOLED") 并在 CI 中显式设置。
  extensions = [pgcrypto, citext]
}

// ---------- 认证 ----------
model User {
  id             String   @id @default(cuid())
  githubId       Int      @unique
  login          String
  name           String?
  email          String?  @db.Citext
  avatarUrl      String?
  accessTokenEnc String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions      Session[]
  installations Installation[]
  jobs          TranslationJob[]

  @@index([login])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- GitHub App ----------
model Installation {
  id                   String    @id @default(cuid())
  githubInstallationId Int       @unique
  userId               String
  accountLogin         String
  accountType          String
  suspendedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]

  @@index([userId])
}

model Repository {
  id             String   @id @default(cuid())
  githubRepoId   Int      @unique
  installationId String
  fullName       String
  defaultBranch  String   @default("main")
  private        Boolean  @default(false)
  isEnabled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  config       RepoConfig?
  jobs         TranslationJob[]
  files        FileTranslation[]

  @@index([installationId])
  @@index([fullName])
}

model RepoConfig {
  id                 String   @id @default(cuid())
  repositoryId       String   @unique
  defaultTargetLangs String[] @default([])
  ignoreGlobs        Json     @default("[]")
  glossaryPath       String   @default(".github/i18n.yaml")
  branchStrategy     String   @default("append")
  dailyCharLimit     Int      @default(500000)
  updatedAt          DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
}

// ---------- 翻译任务（M2 MVP；对齐 TechDesign §3.2）----------
model TranslationJob {
  id           String    @id @default(cuid())
  repositoryId String
  userId       String
  status       String    @default("pending")
  /// manual | webhook | retry
  trigger      String    @default("manual")
  commitSha    String?
  targetLangs  String[]
  modelId      String
  branchName   String?
  prUrl        String?
  totalFiles   Int       @default(0)
  doneFiles    Int       @default(0)
  failedFiles  Int       @default(0)
  errorMessage String?
  queuedAt     DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  repository Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  files      FileTranslation[]

  @@index([status, queuedAt])
  @@index([repositoryId, queuedAt])
}

model FileTranslation {
  id             String    @id @default(cuid())
  jobId          String
  repositoryId   String
  path           String
  lang           String
  sourceHash     String    @default("")
  translatedHash String?
  tokensIn       Int       @default(0)
  tokensOut      Int       @default(0)
  durationMs     Int       @default(0)
  status         String    @default("queued")
  skipReason     String?
  errorMessage   String?
  /// 实际完成翻译的 OpenRouter 模型 ID（可能与任务首选模型不同，例如触发降级）
  modelUsed      String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  job        TranslationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  repository Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, path, lang, createdAt(sort: Desc)])
  @@index([repositoryId, path, lang, sourceHash])
  @@index([jobId, status])
}

// ---------- Webhook 审计（M2；对齐 TechDesign §3.2）----------
model WebhookEvent {
  id             String    @id @default(cuid())
  deliveryId     String    @unique
  eventType      String
  /// 本站 `Installation.id`；未知时常为 null
  installationId String?
  payload        Json
  status         String    @default("pending")
  errorMessage   String?
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?

  @@index([status, receivedAt])
}
