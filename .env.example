# 复制为根目录 `.env` 并填入真实值（Prisma CLI 只读 `.env`，不读 `.env.local`）。可另用 `.env.local` 给 Next 覆盖。禁止提交真实密钥。
# Vercel / CI：`pnpm run build` 会执行 `prisma migrate deploy`，两变量缺一不可；缺 `DATABASE_URL_UNPOOLED` 会 P1012。

# --- 数据库（Neon：pooled + 直连迁移；本机无 pooler 时两变量可相同）---
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# --- GitHub App（Dev / Prod 分环境，勿混用）---
# GitHub App → 设置 / Developer settings：
#  - Home page URL: 与 NEXT_PUBLIC_APP_URL 一致（例 https://…vercel.app 或 http://localhost:3000）
#  - Authorization callback URL（可多条）:
#    https://hyd-github-global-jgdzq8v2l-tryubests-projects.vercel.app/api/auth/github/callback
#    http://localhost:3000/api/auth/github/callback
GITHUB_APP_ID="123456"
GITHUB_APP_CLIENT_ID="Iv1.xxxxxxxxxxxxxxxx"
GITHUB_APP_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GITHUB_APP_PRIVATE_KEY_BASE64="LS0tLS1CRUdJTi..." 
GITHUB_APP_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- OpenRouter ---
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxx"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
TRANSLATION_MODEL_PRIMARY="z-ai/glm-4.5-air:free"
TRANSLATION_MODEL_FALLBACK="qwen/qwen3-next-80b-a3b-instruct:free"

# --- 会话 / 加密（生产环境须独立生成）---
ENCRYPTION_KEY="base64:REPLACE_WITH_32_BYTES_BASE64"
SESSION_SECRET="base64:REPLACE_WITH_RANDOM_SECRET"

# --- Worker（GitHub Actions cron 调用头）---
CRON_SECRET="REPLACE_WITH_LONG_RANDOM"

# --- 应用 URL（浏览器可访问的绝对地址）---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
